    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@m5stack-coding-toys/protocol": "workspace:*",
    "serialport": "^13.0.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
