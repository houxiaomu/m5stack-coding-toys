{
  "name": "m5ct",
  "version": "0.1.0",
  "type": "module",
  "description": "M5Stack hardware status display for Claude Code",
  "license": "MIT",
  "author": "houxiaomu",
  "homepage": "https://github.com/houxiaomu/m5stack-coding-toys#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/houxiaomu/m5stack-coding-toys.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/houxiaomu/m5stack-coding-toys/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "m5stack",
    "cores3",
    "esp32",
    "status-display",
    "statusline",
    "cli"
  ],
  "bin": {
    "m5ct": "./dist/m5ct.js",
    "m5ctd": "./dist/m5ctd.js",
    "m5ct-statusline": "./dist/m5ct-statusline.js"
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit -p tsconfig.json && node ./build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@m5stack-coding-toys/protocol": "workspace:*",
    "@m5stack-coding-toys/daemon": "workspace:*",
    "@m5stack-coding-toys/statusline-shim": "workspace:*",
    "esptool-js": "^0.6.0",
    "smol-toml": "^1.3.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
